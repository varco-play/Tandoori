# Telegram Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# Admin Telegram Chat IDs for each branch
# To get your chat ID: message @userinfobot on Telegram
PHILADELPHIA_ADMIN_ID=1431921953
PITTSBURGH_ADMIN_ID=7333146382
NEW_YORK_ADMIN_ID=8385757483

# Mode: polling (local dev) or webhook (production)
MODE=webhook

# Port for webhook Express server
PORT=3000

# Public server URL for webhook mode (e.g. https://yourdomain.com)
# Leave empty for polling mode
SERVER_URL=
